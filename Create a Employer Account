<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Create a Employer Account — TalentMatch</title>

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet" />

  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg: #F4F1EC;
      --bg-card: #FDFCFA;
      --ink: #1A1A18;
      --ink-soft: #5C5C54;
      --green: #1A7F5A;
      --green-bg: #E8F5EF;
      --border: rgba(26,26,24,0.1);
      --border-md: rgba(26,26,24,0.18);
    }

    body {
      background: var(--bg);
      color: var(--ink);
      font-family: 'DM Sans', sans-serif;
    }

    nav {
      position: sticky;
      top: 0;
      background: rgba(244,241,236,0.9);
      backdrop-filter: blur(12px);
      border-bottom: 1px solid var(--border);
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 0 2rem;
      height: 60px;
      z-index: 10;
    }

    .nav-logo {
      font-family: 'DM Serif Display', serif;
      font-size: 20px;
      text-decoration: none;
      color: var(--ink);
    }

    .nav-logo span { color: var(--green); }

    .back-link {
      font-size: 14px;
      color: var(--ink-soft);
      text-decoration: none;
    }

    .page {
      max-width: 1050px;
      margin: 70px auto;
      padding: 0 2rem 80px;
    }

    .page-header {
      text-align: center;
      margin-bottom: 40px;
    }

    .page-header h1 {
      font-family: 'DM Serif Display', serif;
      font-size: 40px;
      margin: 12px 0;
    }

    .page-header p {
      color: var(--ink-soft);
      max-width: 650px;
      margin: auto;
      font-size: 15px;
      line-height: 1.6;
    }

    .form-box {
      background: var(--bg-card);
      border: 1px solid var(--border-md);
      border-radius: 16px;
      padding: 32px;
    }

    .form-card {
      padding: 28px 0;
      border-bottom: 1px solid var(--border-md);
    }

    .form-card:first-child { padding-top: 0; }
    .form-card:last-child { border-bottom: none; padding-bottom: 0; }

    h2 {
      margin-bottom: 18px;
      font-size: 20px;
      font-weight: 500;
    }

    label {
      display: block;
      margin-top: 16px;
      margin-bottom: 6px;
      font-size: 13px;
      color: var(--ink-soft);
    }

    input, select, textarea {
      width: 100%;
      padding: 10px;
      border-radius: 8px;
      border: 1px solid var(--border-md);
      background: #F7F5F1;
      font-family: 'DM Sans', sans-serif;
    }

    textarea { resize: vertical; }

    .two-column {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 20px;
    }

    .three-column {
      display: grid;
      grid-template-columns: 1fr 1fr 1fr;
      gap: 14px;
    }

    .logo-upload {
      text-align: center;
      background: var(--green-bg);
      border-radius: 12px;
      padding: 22px;
      border: 1px dashed var(--border-md);
      margin-top: 12px;
    }

    .logo-placeholder {
      width: 120px;
      height: 100px;
      margin: 0 auto 12px;
      background: var(--bg-card);
      border-radius: 10px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 40px;
    }

    button {
      border: 1px solid var(--border-md);
      background: white;
      border-radius: 20px;
      padding: 9px 16px;
      cursor: pointer;
      font-family: 'DM Sans', sans-serif;
    }

    button:hover {
      color: var(--green);
      border-color: var(--green);
    }

    .submit-btn {
      margin-top: 30px;
      width: 100%;
      background: var(--green);
      color: white;
      padding: 14px;
      border: none;
      border-radius: 8px;
      font-weight: 500;
    }

    .skill-tags {
      display: flex;
      gap: 10px;
      margin-bottom: 10px;
      flex-wrap: wrap;
    }

    .skill-tags span {
      background: var(--green-bg);
      color: var(--green);
      padding: 6px 14px;
      border-radius: 20px;
      font-size: 13px;
      border: 1px solid var(--green);
    }

    .hidden { display: none; }

    .small-note {
      color: var(--ink-soft);
      font-size: 13px;
      margin-top: 8px;
    }

    @media (max-width: 768px) {
      .two-column,
      .three-column {
        grid-template-columns: 1fr;
      }

      .page-header h1 {
        font-size: 32px;
      }
    }
  </style>
</head>

<body>

<nav>
  <a href="#" class="nav-logo">Talent<span>Match</span></a>
  <a href="#" class="back-link">← Back</a>
</nav>

<main class="page">

  <!-- PAGE 1: COMPANY ACCOUNT -->
  <section id="companyAccountPage">
    <div class="page-header">
      <h1>Create A Company Account</h1>
      <p>Enter your company details first. Once the employer account is created, you can continue to create a job listing.</p>
    </div>

    <form class="form-box" onsubmit="showJobListingPage(event)">
      <section class="form-card">
        <h2>Company Details</h2>

        <div class="two-column">
          <div>
            <label>Company Name</label>
            <input type="text" required>
          </div>

          <div>
            <label>Industry</label>
            <select required>
              <option value="">Select industry</option>
              <option>Information Technology</option>
              <option>Finance</option>
              <option>Healthcare</option>
              <option>Education</option>
              <option>Engineering</option>
              <option>Marketing</option>
              <option>Government</option>
              <option>Other</option>
            </select>
          </div>
        </div>

        <label>Company Website</label>
        <input type="url" placeholder="https://example.com">

        <label>Company Location</label>
        <input type="text" placeholder="Wollongong, NSW">
      </section>

      <section class="form-card">
        <h2>Employer Contact</h2>

        <div class="two-column">
          <div>
            <label>Contact Full Name</label>
            <input type="text" required>
          </div>

          <div>
            <label>Position / Role</label>
            <input type="text" placeholder="Hiring Manager">
          </div>
        </div>

        <div class="two-column">
          <div>
            <label>Email</label>
            <input type="email" required>
          </div>

          <div>
            <label>Phone Number</label>
            <input type="tel">
          </div>
        </div>
      </section>

      <section class="form-card">
        <h2>Company Logo</h2>
        <p class="small-note">Upload a logo to display with your job listings.</p>

        <div class="logo-upload">
          <div class="logo-placeholder">🏢</div>
          <input type="file" accept="image/*">
        </div>
      </section>

      <section class="form-card">
        <h2>Company Description</h2>
        <textarea rows="5" placeholder="Briefly describe the company, workplace culture, and what candidates should know."></textarea>
      </section>

      <button type="submit" class="submit-btn">Create Account & Continue</button>
    </form>
  </section>

  <!-- PAGE 2: JOB LISTING -->
  <section id="jobListingPage" class="hidden">
    <div class="page-header">
      <h1>Create A Job Listing</h1>
      <p>Add the job details, required skills, education requirements, and application deadline for candidates.</p>
    </div>

    <form class="form-box">
      <section class="form-card">
        <h2>Job Details</h2>

        <div class="two-column">
          <div>
            <label>Job Title</label>
            <input type="text" required>
          </div>

          <div>
            <label>Job Type</label>
            <select required>
              <option value="">Select job type</option>
              <option>Full-time</option>
              <option>Part-time</option>
              <option>Casual</option>
              <option>Internship</option>
              <option>Graduate Program</option>
              <option>Contract</option>
              <option>Remote</option>
              <option>Hybrid</option>
            </select>
          </div>
        </div>

        <div class="two-column">
          <div>
            <label>Location</label>
            <input type="text" placeholder="Sydney, NSW">
          </div>

          <div>
            <label>Experience Level</label>
            <select>
              <option value="">Select experience level</option>
              <option>Entry Level</option>
              <option>Graduate</option>
              <option>Junior</option>
              <option>Mid-level</option>
              <option>Senior</option>
            </select>
          </div>
        </div>

        <label>Salary Range</label>
        <div class="two-column">
          <input type="number" placeholder="Minimum salary">
          <input type="number" placeholder="Maximum salary">
        </div>
      </section>

      <section class="form-card">
        <h2>Required Skills</h2>

        <div class="skill-tags">
          <span>Problem Solving</span>
          <span>HTML</span>
        </div>

        <select>
          <option>Select required skill</option>
          <option>JavaScript</option>
          <option>Python</option>
          <option>Java</option>
          <option>C++</option>
          <option>SQL</option>
          <option>React</option>
          <option>CSS</option>
          <option>Communication</option>
          <option>Teamwork</option>
          <option>Leadership</option>
          <option>Project Management</option>
          <option>Data Analysis</option>
          <option>UI/UX Design</option>
          <option>Cloud Computing</option>
        </select>
      </section>

      <section class="form-card">
        <h2>Education Requirement</h2>

        <label>Level</label>
        <div class="skill-tags">
          <span>Diploma</span>
          <span>Bachelors</span>
        </div>

        <select>
          <option>Select education level</option>
          <option>Certificate</option>
          <option>Diploma</option>
          <option>Advanced Diploma</option>
          <option>Bachelors Degree</option>
          <option>Masters Degree</option>
          <option>No formal requirement</option>
        </select>

        <label>Area</label>
        <div class="skill-tags">
          <span>IT</span>
          <span>Web Design</span>
          <span>Comp Sci</span>
        </div>

        <select>
          <option>Select study area</option>
          <option>Computer Science</option>
          <option>Software Engineering</option>
          <option>Information Technology</option>
          <option>Data Science</option>
          <option>Cyber Security</option>
          <option>Business Information Systems</option>
          <option>Engineering</option>
          <option>Any relevant field</option>
        </select>
      </section>

      <section class="form-card">
        <h2>Job Description</h2>
        <textarea rows="7" placeholder="Describe the role, responsibilities, expectations, and ideal candidate."></textarea>
      </section>

      <section class="form-card">
        <h2>Application Deadline</h2>
        <input type="date">
      </section>

      <button type="submit" class="submit-btn">Publish Job Listing</button>
    </form>
  </section>

</main>

<script>
  function showJobListingPage(event) {
    event.preventDefault();

    document.getElementById("companyAccountPage").classList.add("hidden");
    document.getElementById("jobListingPage").classList.remove("hidden");

    window.scrollTo({ top: 0, behavior: "smooth" });
  }
</script>

</body>
</html>
